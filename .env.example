# ---- Shared local development env. Copy to .env and adjust. ----

# API
API_PORT=6002
NODE_ENV=development

# PostgreSQL
# Host port 5433 avoids clashing with a native Windows PostgreSQL install on 5432.
DATABASE_URL=postgresql://ticketing:ticketing_dev_pw@localhost:5433/ticketing

# Redis
REDIS_URL=redis://localhost:6379

# Auth (placeholders — real values added in later phases)
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# Seat hold (seconds) — 60s (1 min) per client decision.
SEAT_HOLD_TTL_SECONDS=60

# OTP
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5

# Rate limiting (per IP)
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=120

# CORS — comma-separated allowed origins for the API.
CORS_ORIGINS=http://localhost:6001

# NOTE: in production, JWT secrets and ADMIN_API_KEY must NOT be the dev defaults
# above — the API refuses to boot with them when NODE_ENV=production.

# Observability — /metrics (Prometheus) is always on. Tracing is opt-in and must
# be set as a REAL launch env var (it starts before .env is loaded):
#   OTEL_ENABLED=true            # console span exporter (dev)
#   OTEL_EXPORTER_OTLP_ENDPOINT  # e.g. http://collector:4318 → OTLP exporter
#   OTEL_SERVICE_NAME=ticketing-api

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:6002
