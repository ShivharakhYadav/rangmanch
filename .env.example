# ---- Shared local development env. Copy to .env and adjust. ----

# API
API_PORT=6002
NODE_ENV=development

# PostgreSQL
# Host port 5433 avoids clashing with a native Windows PostgreSQL install on 5432.
DATABASE_URL=postgresql://ticketing:ticketing_dev_pw@localhost:5433/ticketing

# Redis
REDIS_URL=redis://localhost:6379

# Auth (placeholders — real values added in later phases)
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# Seat hold (seconds) — 60s (1 min) per client decision.
SEAT_HOLD_TTL_SECONDS=60

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:6002
