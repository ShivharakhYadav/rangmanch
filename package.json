{
  "name": "ticketing-platform",
  "version": "0.0.1",
  "private": true,
  "description": "BookMyShow-class event ticket booking platform (India-first)",
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "db:backup": "docker exec ticketing-postgres pg_dump -U ticketing -Fc ticketing > backups/ticketing.dump",
    "db:restore": "docker exec -i ticketing-postgres pg_restore -U ticketing -d ticketing --clean --if-exists < backups/ticketing.dump",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.20",
    "eslint-config-prettier": "^9.1.2",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.4.2",
    "turbo": "^2.5.6",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.62.1"
  }
}
